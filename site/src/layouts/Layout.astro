---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE, abs } from '../config/site';
import { professionalService, website, breadcrumb, type Crumb } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  path: string;            // canonical path, e.g. '/pricing'
  ogImage?: string;
  ogType?: string;
  breadcrumbs?: Crumb[];    // omit on home
  schemas?: Record<string, any>[]; // page-specific JSON-LD blocks
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  ogImage = SITE.ogImage,
  ogType = 'website',
  breadcrumbs,
  schemas = [],
  noindex = false,
} = Astro.props;

const canonical = abs(path);
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;

// Global schema on every page, plus any page-specific blocks.
const allSchemas: Record<string, any>[] = [
  professionalService(),
  website(),
  ...(breadcrumbs && breadcrumbs.length ? [breadcrumb(breadcrumbs)] : []),
  ...schemas,
];
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- First-touch attribution: remember the page/referrer a visitor first
         arrived on (session-scoped, first-party) so an enquiry can be traced
         back to its source. Read by the contact form on submit. -->
    <script is:inline>
      (function () {
        try {
          var KEY = 'asgs-attribution';
          if (!sessionStorage.getItem(KEY)) {
            sessionStorage.setItem(KEY, JSON.stringify({
              landing: location.pathname + location.search,
              referrer: document.referrer || '',
              ts: new Date().toISOString(),
            }));
          }
        } catch (e) {}
      })();
    </script>

    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />
    <meta name="theme-color" content="#1a1a2e" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600;700&display=swap"
    />

    {allSchemas.map((s) => <JsonLd schema={s} />)}
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
