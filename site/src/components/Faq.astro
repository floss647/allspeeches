---
import type { Faq } from '../lib/schema';
interface Props { faqs: Faq[]; heading?: string; }
const { faqs, heading = 'Frequently asked questions' } = Astro.props;
---
<section class="section section--tint">
  <div class="wrap measure mx-auto">
    <p class="eyebrow center">Good to know</p>
    <h2 class="center">{heading}</h2>
    <div class="faq mt-2">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p set:html={f.a} />
        </details>
      ))}
    </div>
  </div>
</section>
