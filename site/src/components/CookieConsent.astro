---
import { SITE } from '../config/site';
const adsId = SITE.googleAdsId;
const adsLabel = SITE.googleAdsLabel;
const ga4Id = SITE.ga4Id;
const openAiPixelId = SITE.openAiPixelId;
---
<div id="cookie-banner" class="cc" hidden role="dialog" aria-modal="false" aria-label="Cookie consent" aria-describedby="cc-text">
  <div class="cc__inner wrap">
    <p id="cc-text" class="cc__text">
      We use cookies that are essential for this site to work. With your permission we'd also like to
      set <strong>analytics and marketing cookies</strong> (Google Analytics, Google Ads and
      ChatGPT Ads) to understand how the site is used and to measure our advertising. Nothing
      non‑essential is set unless you accept. See our <a href="/privacy">privacy &amp; cookie policy</a>.
    </p>
    <div class="cc__actions">
      <button type="button" data-cc="reject" class="btn btn--ghost cc__btn">Reject</button>
      <button type="button" data-cc="accept" class="btn btn--primary cc__btn">Accept</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ adsId, adsLabel, ga4Id, openAiPixelId }}>
  (function () {
    if (!adsId && !ga4Id && !openAiPixelId) return;
    var NAME = 'asgs-consent';

    // OpenAI / ChatGPT Ads pixel — marketing tracker, so it only loads once
    // the visitor has granted consent. Guarded so it never loads twice.
    var oaiLoaded = false;
    function loadOpenAiPixel() {
      if (oaiLoaded || !openAiPixelId) return;
      oaiLoaded = true;
      !function (w, d, s, u) {
        if (w.oaiq) return;
        var q = function () { q.q.push(arguments); };
        q.q = []; w.oaiq = q;
        var j = d.createElement(s); j.async = 1; j.src = u;
        var f = d.getElementsByTagName(s)[0];
        f.parentNode.insertBefore(j, f);
      }(window, document, 'script', 'https://bzrcdn.openai.com/sdk/oaiq.min.js');
      window.oaiq('init', { pixelId: openAiPixelId, debug: true });
      window.oaiq('measure', 'page_viewed', { type: 'contents' });
    }

    // True when an enquiry has just completed (the /thank-you page).
    var onThankYou = location.pathname.replace(/\/+$/, '') === '/thank-you';

    // Fire the ChatGPT Ads conversion once, only after the pixel is loaded.
    var oaiConverted = false;
    function fireOpenAiConversion() {
      if (oaiConverted || !oaiLoaded || !window.oaiq) return;
      oaiConverted = true;
      window.oaiq('measure', 'registration_completed', {
        type: 'customer_action', amount: 0, currency: 'USD',
      });
    }

    function readConsent() {
      var m = document.cookie.match(/(?:^|;\s*)asgs-consent=([^;]+)/);
      return m ? decodeURIComponent(m[1]) : null;
    }
    function writeConsent(value) {
      var d = new Date();
      d.setMonth(d.getMonth() + 6); // re-ask after 6 months
      document.cookie = NAME + '=' + value + '; path=/; max-age=' + 60 * 60 * 24 * 182 +
        '; expires=' + d.toUTCString() + '; SameSite=Lax';
    }

    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    window.gtag = gtag;

    var choice = readConsent();
    var granted = choice === 'granted';
    var g = granted ? 'granted' : 'denied';

    // Consent Mode v2 (advanced): the tag loads for everyone, but stays
    // cookieless and ad-redacted until consent is granted. GA4 still collects
    // (cookieless/modelled) data from non-consenting visitors, so reports
    // populate; full data once a visitor accepts.
    gtag('consent', 'default', {
      ad_storage: g, ad_user_data: g, ad_personalization: g, analytics_storage: g,
      functionality_storage: 'granted', security_storage: 'granted',
    });
    gtag('set', 'url_passthrough', true);
    gtag('set', 'ads_data_redaction', !granted);

    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + (ga4Id || adsId);
    document.head.appendChild(s);
    gtag('js', new Date());
    if (ga4Id) gtag('config', ga4Id);
    if (adsId) gtag('config', adsId);

    // A conversion only counts when the contact form was actually submitted.
    // The form sets this one-time flag right before redirecting here, so a
    // direct hit, refresh, bot or test view of /thank-you never fires one.
    var realEnquiry = false;
    try {
      realEnquiry = sessionStorage.getItem('asgs-enquiry') === '1';
      if (realEnquiry) sessionStorage.removeItem('asgs-enquiry');
    } catch (e) {}
    var validConversion = onThankYou && realEnquiry;

    // Fire the Ads conversion on a genuine enquiry (respects consent mode).
    if (adsId && adsLabel && validConversion) {
      gtag('event', 'conversion', { send_to: adsId + '/' + adsLabel });
    }

    // Load the OpenAI/ChatGPT Ads pixel for visitors who've already consented,
    // and record the conversion only on a genuine enquiry.
    if (granted) {
      loadOpenAiPixel();
      if (validConversion) fireOpenAiConversion();
    }

    var banner = document.getElementById('cookie-banner');
    function showBanner() { if (banner) banner.hidden = false; }
    function hideBanner() { if (banner) banner.hidden = true; }
    if (choice !== 'granted' && choice !== 'denied') showBanner();

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-cc]');
      if (!btn) return;
      var action = btn.getAttribute('data-cc');
      if (action === 'open') { e.preventDefault(); showBanner(); return; }
      if (action === 'accept') {
        writeConsent('granted');
        gtag('consent', 'update', {
          ad_storage: 'granted', ad_user_data: 'granted',
          ad_personalization: 'granted', analytics_storage: 'granted',
        });
        gtag('set', 'ads_data_redaction', false);
        loadOpenAiPixel();
        // The Ads conversion already fired at init under consent mode; only the
        // OpenAI pixel waits for consent, so fire just that one here.
        if (validConversion) fireOpenAiConversion();
      } else if (action === 'reject') {
        writeConsent('denied');
        gtag('consent', 'update', {
          ad_storage: 'denied', ad_user_data: 'denied',
          ad_personalization: 'denied', analytics_storage: 'denied',
        });
      }
      hideBanner();
    });
  })();
</script>

<style>
  .cc {
    position: fixed; inset: auto 0 0 0; z-index: 1000;
    background: var(--ink); color: #e9e9f2;
    box-shadow: 0 -8px 30px rgba(26, 26, 46, 0.25);
  }
  .cc__inner {
    display: flex; align-items: center; gap: 20px 28px;
    padding-top: 16px; padding-bottom: 16px; flex-wrap: wrap;
  }
  .cc__text { margin: 0; flex: 1 1 360px; font-size: 0.92rem; line-height: 1.55; }
  .cc__text a { color: #fff; text-decoration: underline; }
  .cc__actions { display: flex; gap: 12px; flex: 0 0 auto; }
  .cc__btn { min-width: 120px; }
  .cc .btn--ghost { color: #fff; border-color: rgba(255,255,255,0.4); }
  .cc .btn--ghost:hover { border-color: #fff; }
  @media (max-width: 560px) {
    .cc__actions { width: 100%; }
    .cc__btn { flex: 1 1 0; min-width: 0; }
  }
</style>
