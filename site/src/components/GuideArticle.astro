---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import Faq from './Faq.astro';
import CtaBand from './CtaBand.astro';
import { SITE } from '../config/site';
import { article, faqPage } from '../lib/schema';

interface Props { entry: CollectionEntry<'guides'>; }
const { entry } = Astro.props;
const d = entry.data;
const { Content, headings } = await render(entry);

// Build the quick-links jump menu from the section headings. Each guide's h2s
// are phrased "Question? (Short Label)"; we use the parenthetical as the link
// text and the heading's own slug as the anchor, so the links always match.
const quickLinks = headings
  .filter((h) => h.depth === 2 && /\(([^)]+)\)\s*$/.test(h.text))
  .map((h) => ({ label: h.text.match(/\(([^)]+)\)\s*$/)![1], slug: h.slug }));

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Guides', path: '/#guides' },
  { name: d.headline, path: d.path },
];

const schemas = [
  article({
    headline: d.headline,
    path: d.path,
    datePublished: d.datePublished,
    dateModified: d.dateModified,
    description: d.description,
  }),
  ...(d.faqs.length ? [faqPage(d.faqs)] : []),
];

const updated = new Date(d.dateModified).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });

// Accept a full YouTube URL or a bare video ID and pull out the 11-char ID.
const videoId = d.video
  ? (d.video.match(/(?:youtu\.be\/|v=|embed\/|shorts\/)([\w-]{11})/)?.[1] ?? d.video.trim())
  : null;
---
<Layout title={d.title} description={d.description} path={d.path} ogImage={d.hero} ogType="article" breadcrumbs={crumbs} schemas={schemas}>
  <article>
    <header class="guide-hero">
      <div class="wrap">
        <img class="guide-hero__img" src={d.hero} alt={d.headline} width="1500" height="600" />
      </div>
      <div class="wrap guide-hero__body">
        <Breadcrumbs items={crumbs} />
        <p class="eyebrow">Free guide</p>
        <h1>{d.headline}</h1>
        <div class="byline">
          <img src="/images/adrian-home.jpg" alt="Adrian Simpson" width="44" height="44" />
          <span>By <strong>{SITE.founder}</strong>, professional speechwriter · Updated {updated}</span>
        </div>
      </div>
    </header>

    <div class="section">
      <div class="wrap prose">
        {videoId && (
          <figure class="guide-video">
            <div class="guide-video__frame">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${videoId}`}
                title={`${d.headline} — video guide`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
          </figure>
        )}
        {quickLinks.length > 0 && (
          <nav class="guide-toc" aria-label="Quick links">
            <p class="guide-toc__title">Quick links</p>
            <ul class="guide-toc__list">
              {quickLinks.map((q) => (
                <li><a href={`#${q.slug}`}>{q.label}</a></li>
              ))}
            </ul>
          </nav>
        )}
        <Content />

        <hr />
        <div class="guide-cta">
          <h3>Would you rather I wrote it for you?</h3>
          <p>I write bespoke, original speeches built entirely around your story, no templates, unlimited revisions.</p>
          <a class="btn btn--primary" href={d.service}>{d.serviceLabel} →</a>
        </div>
      </div>
    </div>

    {d.faqs.length > 0 && <Faq faqs={d.faqs} heading="Common questions" />}
  </article>

  <CtaBand />
</Layout>

<style>
  .guide-hero { margin-top: 18px; }
  .guide-hero__img { display: block; width: 100%; aspect-ratio: 5 / 2; object-fit: cover; object-position: center; border-radius: var(--radius); }
  .guide-hero__body { margin-top: 22px; }
  .guide-hero__body h1 { max-width: 760px; margin-top: 0.15em; }
  .guide-video { margin: 0 0 32px; }
  .guide-video__frame { position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); background: var(--ink); }
  .guide-video__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .guide-cta { background: var(--paper-2); border-radius: var(--radius); padding: 28px; text-align: center; }
  .guide-cta h3 { margin-bottom: 0.3em; }
  .guide-toc { background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 18px 22px; margin: 0 0 30px; }
  .guide-toc__title { font-family: var(--sans); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.72rem; font-weight: 600; color: var(--ink-soft); margin: 0 0 10px; }
  .guide-toc__list { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 7px 18px; }
  .guide-toc__list a { color: var(--gold-dark); text-decoration: none; font-size: 0.95rem; }
  .guide-toc__list a:hover { text-decoration: underline; }
  .prose :global(h2), .prose :global(h3) { scroll-margin-top: 90px; }
</style>
