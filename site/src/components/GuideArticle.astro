---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import Faq from './Faq.astro';
import CtaBand from './CtaBand.astro';
import { SITE } from '../config/site';
import { article, faqPage } from '../lib/schema';

interface Props { entry: CollectionEntry<'guides'>; }
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Guides', path: '/#guides' },
  { name: d.headline, path: d.path },
];

const schemas = [
  article({
    headline: d.headline,
    path: d.path,
    datePublished: d.datePublished,
    dateModified: d.dateModified,
    description: d.description,
  }),
  ...(d.faqs.length ? [faqPage(d.faqs)] : []),
];

const updated = new Date(d.dateModified).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });

// Accept a full YouTube URL or a bare video ID and pull out the 11-char ID.
const videoId = d.video
  ? (d.video.match(/(?:youtu\.be\/|v=|embed\/|shorts\/)([\w-]{11})/)?.[1] ?? d.video.trim())
  : null;
---
<Layout title={d.title} description={d.description} path={d.path} ogImage={d.hero} ogType="article" breadcrumbs={crumbs} schemas={schemas}>
  <article>
    <header class="guide-hero">
      <div class="wrap">
        <img class="guide-hero__img" src={d.hero} alt={d.headline} width="1500" height="600" />
      </div>
      <div class="wrap guide-hero__body">
        <Breadcrumbs items={crumbs} />
        <p class="eyebrow">Free guide</p>
        <h1>{d.headline}</h1>
        <div class="byline">
          <img src="/images/adrian-home.jpg" alt="Adrian Simpson" width="44" height="44" />
          <span>By <strong>{SITE.founder}</strong>, professional speechwriter · Updated {updated}</span>
        </div>
      </div>
    </header>

    <div class="section">
      <div class="wrap prose">
        {videoId && (
          <figure class="guide-video">
            <div class="guide-video__frame">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${videoId}`}
                title={`${d.headline} — video guide`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
          </figure>
        )}
        <Content />

        <hr />
        <div class="guide-cta">
          <h3>Would you rather I wrote it for you?</h3>
          <p>I write bespoke, original speeches built entirely around your story, no templates, unlimited revisions.</p>
          <a class="btn btn--primary" href={d.service}>{d.serviceLabel} →</a>
        </div>
      </div>
    </div>

    {d.faqs.length > 0 && <Faq faqs={d.faqs} heading="Common questions" />}
  </article>

  <CtaBand />
</Layout>

<style>
  .guide-hero { margin-top: 18px; }
  .guide-hero__img { display: block; width: 100%; aspect-ratio: 5 / 2; object-fit: cover; object-position: center; border-radius: var(--radius); }
  .guide-hero__body { margin-top: -56px; position: relative; }
  .guide-hero__body h1 { background: var(--paper); display: inline-block; padding: 10px 16px; margin-left: -16px; border-radius: 8px; max-width: 760px; }
  .guide-video { margin: 0 0 32px; }
  .guide-video__frame { position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); background: var(--ink); }
  .guide-video__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .guide-cta { background: var(--paper-2); border-radius: var(--radius); padding: 28px; text-align: center; }
  .guide-cta h3 { margin-bottom: 0.3em; }
</style>
