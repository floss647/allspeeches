---
import { SITE } from '../config/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href.replace(/\/$/, ''));

const services = [
  ['/best-man-speech-writer/', 'Best Man'],
  ['/groom-speech-writer', 'Groom'],
  ['/father-of-the-bride-speech-writer', 'Father of the Bride'],
  ['/maid-of-honour-speech-writer', 'Maid of Honour'],
  ['/mother-of-the-groom-speech-writer', 'Mother of the Groom'],
  ['/sister-of-the-groom-speech-writer', 'Sister of the Groom'],
  ['/eulogy-writing-service', 'Eulogy'],
  ['/speech-review-service', 'Speech Review'],
  ['/after-dinner-speeches/', 'After-Dinner'],
];
const guides = [
  ['/best-man-speeches/', 'Best Man Guide'],
  ['/groom-speeches', 'Groom Guide'],
  ['/father-of-the-bride-speeches', 'Father of the Bride Guide'],
  ['/moh-speeches', 'Maid of Honour Guide'],
  ['/eulogy-examples', 'Eulogy Guide'],
];
const business = [
  ['/corporate-speeches', 'Corporate speechwriting'],
  ['/keynote-speech-writer', 'Keynote & Conference'],
  ['/ted-style-talk-writer', 'TED-style Talk'],
  ['/executive-speech-writer', 'Executive & Leadership'],
  ['/award-ceremony-speech-writer', 'Awards & Hosting'],
  ['/after-dinner-speeches/', 'After-Dinner'],
];
const isCorporate = business.some(([href]) => isActive(href as string));
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.shortName} home`}>
      <img src="/images/logo.png" alt={`${SITE.shortName} logo`} width="400" height="57" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu"><span></span></label>

    <nav class="nav" aria-label="Primary">
      <ul class="nav__list">
        <li class="has-sub">
          <span class="nav__link">Services ▾</span>
          <ul class="sub">
            {services.map(([href, label]) => (
              <li><a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a></li>
            ))}
          </ul>
        </li>
        <li class="has-sub">
          <span class="nav__link">Guides ▾</span>
          <ul class="sub">
            {guides.map(([href, label]) => (
              <li><a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a></li>
            ))}
          </ul>
        </li>
        <li class="has-sub">
          <span class="nav__link">For Business ▾</span>
          <ul class="sub">
            {business.map(([href, label]) => (
              <li><a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a></li>
            ))}
          </ul>
        </li>
        <li><a class="nav__link" href={SITE.founderUrlPath} aria-current={isActive(SITE.founderUrlPath) ? 'page' : undefined}>About</a></li>
        <li><a class="nav__link" href="/reviews" aria-current={isActive('/reviews') ? 'page' : undefined}>Reviews</a></li>
        <li><a class="nav__link" href="/pricing" aria-current={isActive('/pricing') ? 'page' : undefined}>Pricing</a></li>
        <li><a class="nav__link" href="/blogs/" aria-current={isActive('/blogs') ? 'page' : undefined}>Blog</a></li>
        <li><a class="btn btn--primary nav__cta" href="/contact">{isCorporate ? 'Discuss your event' : 'Let’s get started'}</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,253,249,0.92); backdrop-filter: blur(8px); border-bottom: 1px solid var(--line); }
  .site-header__inner { display: flex; align-items: center; justify-content: space-between; min-height: 72px; gap: 18px; }
  .brand { display: inline-flex; align-items: center; text-decoration: none; }
  .brand img { display: block; height: 30px; width: auto; }
  @media (max-width: 480px) { .brand img { height: 26px; } }
  .nav__list { display: flex; align-items: center; gap: 6px; list-style: none; margin: 0; padding: 0; }
  .nav__link { display: inline-block; padding: 10px 12px; font-size: 0.98rem; font-weight: 500; color: var(--ink); text-decoration: none; cursor: pointer; border-radius: 8px; white-space: nowrap; }
  a.nav__link:hover { color: var(--gold-dark); }
  .nav__link[aria-current="page"] { color: var(--gold-dark); }
  .has-sub { position: relative; }
  .sub { position: absolute; top: 100%; left: 0; min-width: 240px; background: #fff; border: 1px solid var(--line); border-radius: 12px; box-shadow: var(--shadow); list-style: none; margin: 6px 0 0; padding: 8px; opacity: 0; visibility: hidden; transform: translateY(6px); transition: all 0.15s ease; }
  .has-sub:hover .sub, .has-sub:focus-within .sub { opacity: 1; visibility: visible; transform: translateY(0); }
  .sub a { display: block; padding: 9px 12px; border-radius: 8px; text-decoration: none; color: var(--ink); font-size: 0.95rem; }
  .sub a:hover { background: var(--paper-2); color: var(--gold-dark); }
  .nav__cta { margin-left: 6px; padding: 9px 16px; white-space: nowrap; font-size: 0.92rem; }
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 1040px) {
    .nav-burger { display: block; width: 30px; height: 24px; position: relative; cursor: pointer; }
    .nav-burger span, .nav-burger span::before, .nav-burger span::after { content: ''; position: absolute; left: 0; width: 100%; height: 2px; background: var(--ink); transition: 0.2s; }
    .nav-burger span { top: 11px; }
    .nav-burger span::before { top: -8px; } .nav-burger span::after { top: 8px; }
    .nav { position: fixed; inset: 72px 0 auto 0; background: var(--paper); border-bottom: 1px solid var(--line); max-height: 0; overflow: hidden; transition: max-height 0.25s ease; }
    .nav__list { flex-direction: column; align-items: stretch; padding: 16px 22px 28px; gap: 4px; }
    .nav-toggle:checked ~ .nav { max-height: 90vh; overflow-y: auto; }
    .sub { position: static; opacity: 1; visibility: visible; transform: none; box-shadow: none; border: none; padding: 0 0 0 12px; margin: 2px 0 8px; }
    .has-sub > .nav__link { color: var(--gold-dark); }
    .nav__cta { margin: 10px 0 0; text-align: center; }
  }
</style>
