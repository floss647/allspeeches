---
import { SITE } from '../config/site';
const formEndpoint = SITE.formEndpoint;
---

<!-- Floating call-booking widget — bottom-right corner -->
<div id="bw-widget">
  <button id="bw-toggle" aria-label="Book a call with Adrian" aria-expanded="false">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Book a call</span>
  </button>

  <div id="bw-panel" role="dialog" aria-label="Book a call with Adrian" hidden>
    <div id="bw-header">
      <div>
        <strong>Book a call</strong>
        <p>Adrian will confirm your slot by email</p>
      </div>
      <button id="bw-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <form id="bw-form">
      <input type="hidden" name="_subject" value="Call booking request via allspeechesgreatandsmall.com" />
      <input type="hidden" name="form_type" value="call_booking" />
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="lead_source" value="" />
      <input type="hidden" name="landing_page" value="" />
      <input type="hidden" name="referrer" value="" />
      <input type="hidden" name="enquiry_page" value="" />

      <label>Your name <input type="text" name="name" placeholder="e.g. James Smith" required /></label>
      <label>Email <input type="email" name="email" placeholder="your@email.com" required /></label>
      <label>Phone <input type="tel" name="phone" placeholder="+44 7700 000000" required /></label>
      <label>Preferred date <input type="date" name="date" required /></label>
      <label>Preferred call time
        <input type="time" name="call_time" min="09:00" max="20:00" required />
        <span class="bw-hint">Between 9:00 and 20:00</span>
      </label>

      <button type="submit" id="bw-submit">Request call</button>
    </form>

    <div id="bw-success" hidden>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
        <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p><strong>Request sent!</strong></p>
      <p>Adrian will email you to confirm your slot.</p>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  // Keep widget above the cookie banner when it's visible
  var widget = document.getElementById('bw-widget');
  var banner = document.getElementById('cookie-banner');
  function reposition() {
    if (banner && !banner.hidden) {
      widget.style.bottom = (banner.offsetHeight + 12) + 'px';
    } else {
      widget.style.bottom = '24px';
    }
  }
  reposition();
  if (banner) {
    new MutationObserver(reposition).observe(banner, { attributes: true, attributeFilter: ['hidden'] });
  }
})();

(function () {
  // Attribution tracking — same logic as the contact form
  var bwForm = document.getElementById('bw-form');
  var src = {};
  try { src = JSON.parse(sessionStorage.getItem('asgs-attribution') || '{}'); } catch (e) {}
  var landing = src.landing || (location.pathname + location.search);
  var referrer = src.referrer || '';

  function detect(landing, referrer) {
    var q = ''; var qi = landing.indexOf('?');
    if (qi >= 0) q = landing.slice(qi + 1);
    var p = new URLSearchParams(q.toLowerCase());
    var s = (p.get('utm_source') || ''); var m = (p.get('utm_medium') || '');
    var ref = (referrer || '').toLowerCase();
    if (s.indexOf('chatgpt') >= 0 || s.indexOf('openai') >= 0 ||
        ref.indexOf('chatgpt.com') >= 0 || ref.indexOf('openai.com') >= 0)
      return 'ChatGPT Ads';
    if (p.has('gclid') || (s.indexOf('google') >= 0 && (m.indexOf('cpc') >= 0 || m.indexOf('paid') >= 0)))
      return 'Google Ads';
    if (p.has('msclkid')) return 'Microsoft Ads';
    if (p.has('fbclid') || ref.indexOf('facebook') >= 0 || ref.indexOf('instagram') >= 0) return 'Facebook / Instagram';
    if (s) return 'Campaign: ' + s + (m ? ' / ' + m : '');
    if (ref.indexOf('google.') >= 0) return 'Google (organic search)';
    if (ref.indexOf('bing.') >= 0) return 'Bing (organic search)';
    if (ref.indexOf('duckduckgo') >= 0) return 'DuckDuckGo (organic search)';
    if (ref) {
      try {
        var h = new URL(referrer).hostname.replace(/^www\./, '');
        if (h && h.indexOf('allspeechesgreatandsmall') < 0) return 'Referral: ' + h;
      } catch (e) {}
    }
    return 'Direct / unknown';
  }

  function setField(name, val) {
    var el = bwForm.querySelector('input[name="' + name + '"]');
    if (el) el.value = val;
  }
  setField('landing_page', landing);
  setField('referrer', referrer || '(none / direct)');
  setField('enquiry_page', location.pathname);
  setField('lead_source', detect(landing, referrer));
})();

(function () {
  var toggle  = document.getElementById('bw-toggle');
  var panel   = document.getElementById('bw-panel');
  var closeBtn = document.getElementById('bw-close');
  var form    = document.getElementById('bw-form');
  var success = document.getElementById('bw-success');
  var submit  = document.getElementById('bw-submit');

  // Set min date to tomorrow
  var dateInput = form.querySelector('input[name="date"]');
  var tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  dateInput.min = tomorrow.toISOString().split('T')[0];

  function open() {
    panel.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    form.querySelector('input[name="name"]').focus();
  }
  function close() {
    panel.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.focus();
  }

  // Allow any [data-open-booking] element on the page to trigger this widget
  window.openBookingWidget = open;
  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('[data-open-booking]');
    if (trigger) { e.preventDefault(); open(); }
  });

  toggle.addEventListener('click', function () {
    panel.hidden ? open() : close();
  });
  closeBtn.addEventListener('click', close);

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    submit.disabled = true;
    submit.textContent = 'Sending…';

    fetch('https://formspree.io/f/mkoaagyj', {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    })
      .then(function (r) {
        if (r.ok) {
          form.hidden = true;
          success.hidden = false;
        } else {
          throw new Error('error');
        }
      })
      .catch(function () {
        submit.disabled = false;
        submit.textContent = 'Request call';
        alert('Sorry, something went wrong. Please try again or email Adrian directly.');
      });
  });
})();
</script>

<style>
  #bw-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9000;
    font-family: var(--sans, Inter, sans-serif);
    font-size: 0.9rem;
  }

  #bw-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 20px 0 14px;
    height: 48px;
    border-radius: 999px;
    background: var(--gold, #b08d57);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,0.22);
    font: 600 0.92rem var(--sans, Inter, sans-serif);
    white-space: nowrap;
    transition: background 0.15s, transform 0.15s;
  }
  #bw-toggle:hover { background: var(--gold-dark, #8c6d3f); transform: translateY(-2px); }
  #bw-toggle:focus-visible { outline: 2px solid var(--gold, #b08d57); outline-offset: 3px; }

  #bw-panel {
    position: absolute;
    bottom: 60px;
    right: 0;
    width: 300px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    overflow: hidden;
    animation: bw-in 0.18s ease;
  }
  #bw-panel[hidden] { display: none; }

  @keyframes bw-in {
    from { opacity: 0; transform: translateY(8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  #bw-header {
    background: var(--ink, #1a1a2e);
    color: #fff;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  #bw-header strong { display: block; font-size: 0.95rem; }
  #bw-header p { margin: 2px 0 0; font-size: 0.77rem; opacity: 0.72; }

  #bw-close {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    opacity: 0.7;
    padding: 4px;
    display: flex;
    align-items: center;
    border-radius: 6px;
    flex-shrink: 0;
  }
  #bw-close:hover { opacity: 1; background: rgba(255,255,255,0.12); }

  #bw-form {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #bw-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink, #1a1a2e);
  }
  #bw-form input,
  #bw-form select {
    padding: 8px 10px;
    border: 1px solid #d0d0da;
    border-radius: 8px;
    font: inherit;
    font-size: 0.875rem;
    background: #fafafa;
    color: var(--ink, #1a1a2e);
    transition: border-color 0.15s;
  }
  #bw-form input:focus,
  #bw-form select:focus {
    outline: none;
    border-color: var(--gold, #b08d57);
    background: #fff;
  }

  .bw-hint { font-size: 0.72rem; font-weight: 400; color: #888; margin-top: 2px; }

  #bw-submit {
    margin-top: 4px;
    padding: 10px;
    border-radius: 8px;
    background: var(--gold, #b08d57);
    color: #fff;
    border: none;
    font: 600 0.92rem var(--sans, Inter, sans-serif);
    cursor: pointer;
    transition: background 0.15s;
  }
  #bw-submit:hover { background: var(--gold-dark, #8c6d3f); }
  #bw-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  #bw-success {
    padding: 32px 20px;
    text-align: center;
    color: var(--ink, #1a1a2e);
  }
  #bw-success svg { color: var(--gold, #b08d57); margin: 0 auto 12px; display: block; }
  #bw-success p { margin: 0 0 6px; font-size: 0.9rem; }
  #bw-success[hidden] { display: none; }

  @media (max-width: 360px) {
    #bw-panel { width: calc(100vw - 32px); }
    #bw-toggle span { display: none; }
    #bw-toggle { padding: 0 14px; width: 48px; border-radius: 50%; justify-content: center; }
  }
</style>
