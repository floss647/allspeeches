---
import { SITE } from '../config/site';
interface Props { heading?: string; text?: string; }
const {
  heading = "Let's write something unforgettable",
  text = "The sooner we start, the more relaxed you'll feel on the day.",
} = Astro.props;
---
<section class="section section--ink center">
  <div class="wrap measure mx-auto">
    <h2>{heading}</h2>
    <p class="lede" style="color:#cfcfe0">{text}</p>
    <div class="btn-row" style="justify-content:center">
      <a class="btn btn--primary" href="/contact">Get my speech written for £{SITE.price}</a>
      <a class="btn btn--ghost" href="/reviews">Read my reviews</a>
    </div>
  </div>
</section>
