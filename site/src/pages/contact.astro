---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { contactPage } from '../lib/schema';
import { SITE } from '../config/site';

const path = '/contact';
const title = 'Contact | All Speeches Great & Small';
const description =
  'Get in touch with Adrian Simpson to start your speech. Send a message for fast, friendly replies. Speeches written worldwide from our UK base.';
const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path },
];
const types = ['Best Man', 'Groom', 'Bride', 'Father of the Bride', 'Mother of the Bride', 'Maid of Honour', 'Brother of the Bride', 'Sister of the Groom', 'Eulogy', 'Business / Corporate', 'Other'];

// If a Formspree (or similar) endpoint is configured, post there and bypass
// Netlify Forms entirely. Otherwise fall back to Netlify Forms.
const useFormspree = SITE.formEndpoint.length > 0;
const formAction = useFormspree ? SITE.formEndpoint : '/thank-you';
const thankYouUrl = `${SITE.url}/thank-you`;
---
<Layout title={title} description={description} path={path} breadcrumbs={crumbs} schemas={[contactPage()]}>
  <section class="hero">
    <div class="wrap">
      <Breadcrumbs items={crumbs} />
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="lede measure">Ready to start, or just want to ask a question? I'd love to hear from you, and I reply quickly and personally.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="form-wrap measure mx-auto">
        <h2>Send me a message</h2>
        <!-- Posts to Formspree when SITE.formEndpoint is set (bypasses Netlify),
             otherwise uses Netlify Forms. Both redirect to /thank-you on success. -->
        <form name="contact" method="POST" action={formAction} class="form"
          data-netlify={useFormspree ? undefined : 'true'}
          netlify-honeypot={useFormspree ? undefined : 'bot-field'}>
          {useFormspree ? (
            <Fragment>
              <input type="hidden" name="_next" value={thankYouUrl} />
              <input type="hidden" name="_subject" value="New enquiry via allspeechesgreatandsmall.com" />
              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
            </Fragment>
          ) : (
            <Fragment>
              <input type="hidden" name="form-name" value="contact" />
              <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
            </Fragment>
          )}

          <label>Your name<input type="text" name="name" required /></label>
          <label>Email address<input type="email" name="email" required /></label>
          <label>Phone (optional)<input type="tel" name="phone" /></label>
          <label>Type of speech
            <select name="speech_type">
              {types.map((t) => <option value={t}>{t}</option>)}
            </select>
          </label>
          <label>Let me know when you'd like to speak<textarea name="message" rows="5"></textarea></label>

          <!-- Populated on submit by the attribution script below. -->
          <input type="hidden" name="lead_source" value="" />
          <input type="hidden" name="landing_page" value="" />
          <input type="hidden" name="referrer" value="" />
          <input type="hidden" name="enquiry_page" value="" />

          <button class="btn btn--primary" type="submit">Send message</button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.querySelector('form[name="contact"]');
      if (!form) return;
      var src = {};
      try { src = JSON.parse(sessionStorage.getItem('asgs-attribution') || '{}'); } catch (e) {}
      var landing = src.landing || (location.pathname + location.search);
      var referrer = src.referrer || '';

      function detect(landing, referrer) {
        var q = ''; var qi = landing.indexOf('?');
        if (qi >= 0) q = landing.slice(qi + 1);
        var p = new URLSearchParams(q.toLowerCase());
        var s = (p.get('utm_source') || ''); var m = (p.get('utm_medium') || '');
        var ref = (referrer || '').toLowerCase();
        if (s.indexOf('chatgpt') >= 0 || s.indexOf('openai') >= 0 ||
            ref.indexOf('chatgpt.com') >= 0 || ref.indexOf('openai.com') >= 0)
          return 'ChatGPT Ads';
        if (p.has('gclid') || (s.indexOf('google') >= 0 && (m.indexOf('cpc') >= 0 || m.indexOf('paid') >= 0)))
          return 'Google Ads';
        if (p.has('msclkid')) return 'Microsoft Ads';
        if (p.has('fbclid') || ref.indexOf('facebook') >= 0 || ref.indexOf('instagram') >= 0) return 'Facebook / Instagram';
        if (s) return 'Campaign: ' + s + (m ? ' / ' + m : '');
        if (ref.indexOf('google.') >= 0) return 'Google (organic search)';
        if (ref.indexOf('bing.') >= 0) return 'Bing (organic search)';
        if (ref.indexOf('duckduckgo') >= 0) return 'DuckDuckGo (organic search)';
        if (ref) {
          try {
            var h = new URL(referrer).hostname.replace(/^www\./, '');
            if (h && h.indexOf('allspeechesgreatandsmall') < 0) return 'Referral: ' + h;
          } catch (e) {}
        }
        return 'Direct / unknown';
      }

      function set(name, val) { var el = form.querySelector('input[name="' + name + '"]'); if (el) el.value = val; }
      set('landing_page', landing);
      set('referrer', referrer || '(none / direct)');
      set('enquiry_page', location.pathname);
      set('lead_source', detect(landing, referrer));
    })();
  </script>

  {useFormspree && (
    <script is:inline>
      (function () {
        var form = document.querySelector('form[name="contact"]');
        if (!form) return;
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var btn = form.querySelector('button[type="submit"]');
          if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
          fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          })
            .then(function (r) {
              if (r.ok) {
                // Mark this as a genuine enquiry so /thank-you fires exactly
                // one ad conversion (not on direct hits, refreshes or bots).
                try { sessionStorage.setItem('asgs-enquiry', '1'); } catch (e) {}
                window.location.href = '/thank-you';
                return;
              }
              return r.json().then(function (d) {
                throw new Error((d && d.errors ? d.errors.map(function (x) { return x.message; }).join(', ') : '') || 'error');
              });
            })
            .catch(function () {
              if (btn) { btn.disabled = false; btn.textContent = 'Send message'; }
              alert('Sorry, your message couldn’t be sent just then. Please try again in a moment.');
            });
        });
      })();
    </script>
  )}
</Layout>

<style>
  .contact-line { margin-bottom: 1.2em; }
  .form label { display: block; margin-bottom: 16px; font-weight: 500; font-size: 0.95rem; }
  .form input, .form select, .form textarea { display: block; width: 100%; margin-top: 6px; padding: 12px 14px; border: 1px solid var(--line); border-radius: 10px; font: inherit; font-size: 1rem; background: #fff; }
  .form input:focus, .form select:focus, .form textarea:focus { outline: 2px solid var(--gold); border-color: var(--gold); }
  .form button { margin-top: 8px; }
</style>
