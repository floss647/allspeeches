---
import Layout from '../layouts/Layout.astro';
import FeaturedIn from '../components/FeaturedIn.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, fill } from '../config/site';
import { services } from '../data/services';
import { faqPage, type Faq as FaqType } from '../lib/schema';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';

const title = 'Professional Wedding Speech Writer | All Speeches Great & Small';
const description = fill(
  "The UK's most-reviewed wedding speech writer. Bespoke best man, groom & father of the bride speeches from £399, no templates, no clichés. [REVIEW_COUNT]+ 5★ reviews."
);

const faqs: FaqType[] = [
  { q: 'How does it actually work?', a: 'You share your stories with me, I write a complete speech around them, and we refine it together until it\'s perfect. The whole thing is built from scratch around you.' },
  { q: 'How long does it take?', a: `Most speeches are drafted within ${SITE.turnaround} days, and I can work to tight deadlines, even last-minute, when needed.` },
  { q: 'Is the speech really original?', a: 'Completely. Every speech is written from the ground up for one person. I never reuse jokes, lines or templates.' },
];

const ratingKnown = !SITE.rating.includes('[');
const reviewsKnown = !SITE.reviewCount.includes('[');
---
<Layout title={title} description={description} path="/" schemas={[faqPage(faqs)]}>
  <!-- HERO -->
  <section class="hero hero--home">
    <div class="wrap hero__inner">
      <p class="eyebrow">Bespoke speech writing for every occasion</p>
      <h1>Make your words unforgettable</h1>
      <p class="lede">
        You only get one shot at the speech. Make it the one everyone remembers, for the right
        reasons. I write original, personal speeches built entirely around your story. No templates.
        No recycled jokes. No clichés.
      </p>
      <div class="btn-row mt-2">
        <a class="btn btn--primary" href="/contact" data-open-booking="">Book a call</a>
        <a class="btn btn--ghost" href="/pricing">See what's included · from £{SITE.price}</a>
      </div>
      <p class="trust" style="margin-top:26px">
        <span class="stars">★★★★★</span>
        {ratingKnown && reviewsKnown ? (
          <span>Rated {SITE.rating}/5 from {SITE.reviewCount} reviews</span>
        ) : (
          <span class="ph">Rated [RATING]/5 from [REVIEW_COUNT] reviews</span>
        )}
      </p>
    </div>
  </section>

  <!-- AS FEATURED IN -->
  <FeaturedIn />

  <!-- SERVICES -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow center">The speeches I write</p>
      <h2 class="center">Speeches for every occasion</h2>

      <h3 class="center group-title">Weddings &amp; personal occasions</h3>
      <div class="grid grid--3 mt-2">
        {services.filter((s) => s.audience !== 'corporate').map((s) => (
          <article class="card">
            <a href={s.slug} class="card__imglink" aria-label={s.cardTitle}>
              <img class="card__img" src={s.cardImage} alt={`${s.cardTitle}, professional speech writing`} loading="lazy" width="400" height="267" />
            </a>
            <div class="card__body">
              <h3>{s.cardTitle}</h3>
              <p>{s.cardBlurb}</p>
              <a class="card__link" href={s.slug}>{s.nav} speech writer →</a>
            </div>
          </article>
        ))}
      </div>

      <h3 class="center group-title group-title--business">Business &amp; events</h3>
      <p class="center measure mx-auto group-intro">Ghostwritten in your voice, in complete confidence. Priced per project.</p>
      <div class="grid grid--3 mt-2">
        {services.filter((s) => s.audience === 'corporate').map((s) => (
          <article class="card">
            <a href={s.slug} class="card__imglink" aria-label={s.cardTitle}>
              <img class="card__img" src={s.cardImage} alt={`${s.cardTitle}, professional speech writing`} loading="lazy" width="400" height="267" />
            </a>
            <div class="card__body">
              <h3>{s.cardTitle}</h3>
              <p>{s.cardBlurb}</p>
              <a class="card__link" href={s.slug}>Find out more →</a>
            </div>
          </article>
        ))}
      </div>
      <div class="center mt-2">
        <a class="btn btn--ghost" href="/corporate-speeches">More on corporate speechwriting →</a>
      </div>
    </div>
  </section>

  <!-- WHY WORK WITH ME -->
  <section class="section section--tint">
    <div class="wrap media">
      <div>
        <p class="eyebrow">Why work with me</p>
        <h2>The best idea ever? Letting a professional write it.</h2>
        <p>
          I'm Adrian Simpson. I started out as a magazine journalist in London, spent fifteen years
          in television, including presenting on BBC Top Gear, and I've been writing speeches
          professionally since 2012. In that time I've become the UK's most highly rated and reviewed
          wedding speech writer.
        </p>
        <p>
          Every speech I write is original and built around you: your relationship, your memories,
          your sense of humour. I don't keep a drawer of stock jokes. I listen, I find the story only
          you can tell, and I write it so it sounds like the best possible version of you, not like a
          speechwriter.
        </p>
        <a class="btn btn--ghost" href={SITE.founderUrlPath}>Read my story →</a>
      </div>
      <img src="/images/adrian-portrait.jpg" alt="Adrian Simpson, professional wedding speechwriter" loading="lazy" width="520" height="600" />
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section">
    <div class="wrap measure mx-auto">
      <p class="eyebrow center">How it works</p>
      <h2 class="center">Three simple steps to a speech you'll be proud of</h2>
      <ol class="steps mt-2">
        <li><strong>Tell me your stories.</strong> A relaxed chat or a simple questionnaire, you give me the people, the memories and the moments.</li>
        <li><strong>I write your draft.</strong> A complete, polished speech, crafted around what you've told me, delivered in {SITE.turnaround} days.</li>
        <li><strong>We make it perfect.</strong> Unlimited tweaks until every word feels right and sounds like you.</li>
      </ol>
    </div>
  </section>

  <!-- REVIEWS TEASER -->
  <section class="section section--tint center">
    <div class="wrap">
      <p class="eyebrow">My verified reviews</p>
      <h2>Don't take my word for it</h2>
      <p class="lede">
        <span class="stars">★★★★★</span>
        {ratingKnown && reviewsKnown ? (
          <span> {SITE.rating}/5 from {SITE.reviewCount} verified reviews.</span>
        ) : (
          <span class="ph"> [RATING]/5 from [REVIEW_COUNT] verified reviews.</span>
        )}
      </p>
      <ReviewsCarousel />
      <div class="mt-2"><a class="btn btn--ghost" href="/reviews">Read all reviews →</a></div>
    </div>
  </section>

  <!-- PRICING TEASER -->
  <section class="section">
    <div class="wrap measure mx-auto center">
      <p class="eyebrow">Simple pricing</p>
      <h2>One simple price. Everything included.</h2>
      <p class="lede">
        A bespoke wedding speech is a flat <strong>£{SITE.price}</strong>, including your stories
        woven in, a complete written speech, and unlimited revisions until it's right. No hidden
        extras.
      </p>
      <a class="btn btn--primary" href="/pricing">See what's included →</a>
    </div>
  </section>

  <Faq faqs={faqs} heading="Questions people ask before getting in touch" />

  <CtaBand />
</Layout>

<style>
  .group-title { margin-top: 40px; font-size: 1.5rem; }
  .group-title--business { margin-top: 64px; }
  .group-intro { color: var(--ink-soft); margin-top: 6px; }
  .card__imglink { display: block; overflow: hidden; border-radius: var(--radius) var(--radius) 0 0; }
  .card__imglink .card__img { transition: transform 0.3s ease; }
  .card__imglink:hover .card__img { transform: scale(1.04); }
</style>
