---
import Layout from '../layouts/Layout.astro';

const path = '/thank-you';
const title = 'Thank you | All Speeches Great & Small';
const description = 'Thank you — your message has been received.';
// The Google Ads conversion is fired by the cookie-consent component once
// marketing consent has been granted (it detects this /thank-you page).
---
<Layout title={title} description={description} path={path} noindex>
  <section class="hero">
    <div class="wrap measure mx-auto center">
      <p class="eyebrow center">Message received</p>
      <h1>Thank you</h1>
      <p class="lede">
        Your message has landed safely with me. I read every enquiry personally and aim to reply
        within one working day — often sooner. Working to a tight deadline? Don't worry, last-minute
        speeches are often possible.
      </p>
      <div class="btn-row mt-2" style="justify-content:center">
        <a class="btn btn--primary" href="/">Back to home</a>
        <a class="btn btn--ghost" href="/blogs/">Read the speech-writing blog</a>
      </div>
    </div>
  </section>
</Layout>
