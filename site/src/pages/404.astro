---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found | All Speeches Great & Small" description="Sorry, we couldn't find that page." path="/404" noindex={true}>
  <section class="section center" style="padding-top:80px">
    <div class="wrap measure mx-auto">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page</h1>
      <p class="lede">The page may have moved. Try one of these instead:</p>
      <div class="btn-row" style="justify-content:center">
        <a class="btn btn--primary" href="/">Home</a>
        <a class="btn btn--ghost" href="/best-man-speeches/">Speech guides</a>
        <a class="btn btn--ghost" href="/contact">Contact</a>
      </div>
    </div>
  </section>
</Layout>
