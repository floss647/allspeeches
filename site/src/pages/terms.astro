---
import Layout from '../layouts/Layout.astro';
const path = '/terms';
---
<Layout title="Terms of Service | All Speeches Great & Small" description="The terms on which All Speeches Great & Small provides its speech-writing services." path={path} noindex={true}>
  <section class="section">
    <div class="wrap prose">
      <h1>Terms of Service</h1>
      <p class="ph">Replace this with your full, reviewed terms before launch. Skeleton headings only.</p>
      <h2>The service</h2>
      <p>We write bespoke speeches and provide speech-review feedback as described on this site.</p>
      <h2>Payment</h2>
      <p>Set out your fee, deposit and payment terms here.</p>
      <h2>Revisions</h2>
      <p>Unlimited revisions are included on bespoke wedding speeches until you are happy.</p>
      <h2>Confidentiality</h2>
      <p>Everything you share with us is treated in confidence.</p>
      <h2>Liability</h2>
      <p>Set out your liability terms here.</p>
    </div>
  </section>
</Layout>
