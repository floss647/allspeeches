---
import Layout from '../layouts/Layout.astro';
import FeaturedIn from '../components/FeaturedIn.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
import { SITE } from '../config/site';
import { services } from '../data/services';
import { service, faqPage, type Faq as FaqType } from '../lib/schema';

const path = '/corporate-speeches';
const title = 'Corporate Speechwriter | Keynotes, Conference & Business Talks';
const description =
  'A professional corporate speechwriter for keynotes, conference and TED-style talks, executive addresses, awards and events. Ghostwritten in your voice, in complete confidence, by a former broadcaster.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'For Business', path },
];

// All business services (keynote, TED-style, executive, awards, after-dinner).
const corporate = services.filter((s) => s.audience === 'corporate');
const offerings = corporate.map((s) => ({ title: s.cardTitle, blurb: s.cardBlurb, href: s.slug }));

const faqs: FaqType[] = [
  { q: 'Do you really write both wedding and corporate speeches?', a: 'Yes, and it’s the same craft. Whether it’s a best man or a chief executive, the job is to find the story only you can tell and write it so it sounds like the best possible version of you. The occasion changes; the skill doesn’t.' },
  { q: 'Is everything confidential?', a: 'Completely. I work under NDAs as a matter of routine and handle commercially sensitive, pre-announcement and market-affecting material with full discretion.' },
  { q: 'Will it sound like the speaker, not like a writer?', a: 'Always. I ghostwrite in the speaker’s own voice, so the audience hears them at their most articulate, never a script being read aloud.' },
  { q: 'Can you work with our comms team or the executive’s EA?', a: 'Routinely. I slot into your process, brief with whoever you nominate, and keep drafts, versions and approvals clean and on schedule.' },
  { q: 'How quickly can you turn work around?', a: 'Corporate moments rarely come with much notice. Tell me the deadline and I’ll tell you straight away whether I can meet it; I usually can.' },
  { q: 'How much does it cost?', a: 'Corporate work is quoted per project, because length, complexity and timeline vary far too much for a flat fee. Tell me about your event and I’ll send a clear, tailored proposal. Ongoing work can be arranged on a retainer.' },
];

const schemas = [
  service({
    serviceType: 'Corporate and business speech writing',
    name: 'Corporate speechwriting',
    path,
    description,
    withPrice: false,
  }),
  faqPage(faqs),
];

const ratingKnown = !SITE.rating.includes('[');
const reviewsKnown = !SITE.reviewCount.includes('[');
---
<Layout title={title} description={description} path={path} breadcrumbs={crumbs} schemas={schemas}>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero__inner">
      <p class="eyebrow">For business &amp; events</p>
      <h1>Corporate &amp; business speechwriting</h1>
      <p class="lede">
        A keynote, a conference talk, a town hall, an awards night, the words you stand up and say in
        front of the people who matter are worth getting right. I turn your message into a speech
        that’s clear, persuasive and unmistakably yours, written for the ear and built to land.
      </p>
      <div class="btn-row mt-2">
        <a class="btn btn--primary" href="/contact">Discuss your event</a>
        <a class="btn btn--ghost" href="#offerings">See what I write</a>
      </div>
      <p class="trust" style="margin-top:26px">
        <span class="stars">★★★★★</span>
        {ratingKnown && reviewsKnown ? (
          <span>Rated {SITE.rating}/5 from {SITE.reviewCount} reviews</span>
        ) : (
          <span class="ph">Rated [RATING]/5 from [REVIEW_COUNT] reviews</span>
        )}
        <span>·</span>
        <span>Fifteen years in television · As seen on BBC</span>
      </p>
    </div>
  </section>

  <FeaturedIn />

  <!-- OFFERINGS -->
  <section class="section" id="offerings">
    <div class="wrap">
      <p class="eyebrow center">What I write for business</p>
      <h2 class="center">Speeches and scripts for the moments that count</h2>
      <div class="grid grid--3 mt-2">
        {offerings.map((o) => (
          <article class="card card--text">
            <div class="card__body">
              <h3>{o.title}</h3>
              <p>{o.blurb}</p>
              <a class="card__link" href={o.href}>Find out more →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY COMPANIES TRUST ME (the "feel safe" section) -->
  <section class="section section--tint">
    <div class="wrap">
      <p class="eyebrow center">Why companies trust me with the words that matter</p>
      <h2 class="center">A professional partner, not a risk</h2>
      <div class="grid grid--3 mt-2">
        <div>
          <h3>Complete confidentiality</h3>
          <p>NDAs as standard. Sensitive, pre-announcement and market-affecting material is handled with full discretion.</p>
        </div>
        <div>
          <h3>Ghostwritten in your voice</h3>
          <p>The audience hears the speaker at their most assured, never a script. It sounds like you on your best day.</p>
        </div>
        <div>
          <h3>Built for the ear</h3>
          <p>Fifteen years writing for broadcast means every line is shaped for rhythm, emphasis and the pause that lands a point.</p>
        </div>
        <div>
          <h3>Works with your team</h3>
          <p>I slot into your process, brief with your comms team or the executive’s EA, and keep versions and approvals clean.</p>
        </div>
        <div>
          <h3>Reliable to the deadline</h3>
          <p>Corporate moments rarely come with notice. Tell me the date and I’ll meet it, or tell you straight away if I can’t.</p>
        </div>
        <div>
          <h3>Straightforward invoicing</h3>
          <p>Per-project quotes, POs and retainers all welcome. Clear terms, agreed before any work begins.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO -->
  <section class="section">
    <div class="wrap media">
      <img src="/images/adrian-portrait.jpg" alt="Adrian Simpson, professional speechwriter" loading="lazy" width="520" height="600" />
      <div>
        <p class="eyebrow">Who you’re working with</p>
        <h2>A broadcaster’s ear, a writer’s discipline</h2>
        <p>
          I’m Adrian Simpson. I started as a magazine journalist, spent fifteen years in television
          including presenting on BBC Top Gear, and have written professionally for the spoken word
          since 2012. That broadcast background is exactly what a keynote or a conference talk needs:
          writing made to be heard, timed to the room, and delivered with confidence.
        </p>
        <p>
          I’m also the UK’s most highly rated and reviewed speechwriter, trusted with weddings and
          boardrooms alike, because the craft is the same: find the story only you can tell, and tell
          it brilliantly.
        </p>
        <a class="btn btn--ghost" href={SITE.founderUrlPath}>Read my story →</a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section section--tint center">
    <div class="wrap">
      <p class="eyebrow">Verified reviews</p>
      <h2>Don’t take my word for it</h2>
      <ReviewsCarousel />
      <div class="mt-2"><a class="btn btn--ghost" href="/reviews">Read all reviews →</a></div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section">
    <div class="wrap measure mx-auto center">
      <p class="eyebrow">Pricing</p>
      <h2>Quoted per project</h2>
      <p class="lede">
        Corporate work is priced per project, because length, complexity and timeline vary far too
        much for a flat fee. Tell me about your event and I’ll send a clear, tailored proposal,
        with no obligation. Ongoing work can be arranged on a retainer.
      </p>
      <a class="btn btn--primary" href="/contact">Request a proposal</a>
    </div>
  </section>

  <Faq faqs={faqs} heading="Questions companies ask" />

  <CtaBand
    heading="Let’s talk about your event"
    text="Tell me about the occasion, the audience and the date, and I’ll take it from there."
    ctaLabel="Discuss your event"
  />
</Layout>

<style>
  .card--text { display: flex; }
  .card--text .card__body { padding: 26px; }
</style>
